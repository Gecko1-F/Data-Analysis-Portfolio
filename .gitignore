# ══════════════════════════════════════════════
# .gitignore — Files that should NEVER be on GitHub
# ══════════════════════════════════════════════

# ─── Operating System Files ───
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor/IDE Files ───
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ─── Environment & Secrets ───
.env
.env.local
.env.production
*.pem
*.key
*.cert
config.secret.js
secrets/

# ─── Dependencies (if you ever add npm packages) ───
node_modules/
package-lock.json

# ─── Build artifacts ───
dist/
build/
*.min.js.map
*.min.css.map

# ─── Logs ───
*.log
npm-debug.log*

# ─── Temporary files ───
tmp/
temp/
*.tmp
*.bak
*.backup

# ─── Large/unnecessary image originals ───
images/originals/
*.psd
*.ai
*.sketch
